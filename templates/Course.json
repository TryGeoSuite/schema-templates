{
  "@context": "https://schema.org",
  "@type": "Course",
  "name": "{{COURSE_NAME}}",
  "description": "{{COURSE_DESCRIPTION}}",
  "provider": {
    "@type": "Organization",
    "name": "{{PROVIDER_NAME}}",
    "sameAs": "{{PROVIDER_URL}}"
  },
  "url": "{{COURSE_URL}}",
  "image": "{{COURSE_IMAGE_URL}}",
  "courseMode": "{{COURSE_MODE}}",
  "educationalLevel": "{{EDUCATIONAL_LEVEL}}",
  "inLanguage": "{{LANGUAGE_CODE}}",
  "hasCourseInstance": {
    "@type": "CourseInstance",
    "courseMode": "{{INSTANCE_MODE}}",
    "startDate": "{{START_DATE_ISO}}",
    "endDate": "{{END_DATE_ISO}}",
    "courseWorkload": "{{WORKLOAD}}"
  },
  "offers": {
    "@type": "Offer",
    "price": "{{PRICE}}",
    "priceCurrency": "{{CURRENCY}}",
    "category": "{{OFFER_CATEGORY}}"
  }
}
