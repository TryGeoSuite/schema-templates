{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "{{SITE_NAME}}",
  "url": "{{SITE_URL}}",
  "description": "{{SITE_DESCRIPTION}}",
  "inLanguage": "{{LANGUAGE_CODE}}",
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "{{SEARCH_URL_TEMPLATE}}"
    },
    "query-input": "required name=search_term_string"
  }
}
